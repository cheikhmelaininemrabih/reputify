# Reputify — environment configuration
#
# Nothing here is required to run the demo: with no keys set, Hedera attestation
# and the OpenAI chatbot fall back to clearly-labelled simulated/unconfigured
# modes so the app always runs end to end. Fill these in to go "live".

# ── Hedera (attestation-and-lending module: /rep /borrower /lender /attester) ──
# Create a testnet account at https://portal.hedera.com, then set:
HEDERA_NETWORK=testnet
HEDERA_OPERATOR_ID=
HEDERA_OPERATOR_KEY=
# Optional: pin to one topic instead of letting the app create one on first attestation.
HEDERA_ATTEST_TOPIC_ID=

# ── OpenAI (help chatbot) ──
OPENAI_API_KEY=

# ── Server-side secret ──
# Key used to seal PSP OAuth tokens at rest in the attestation module.
# CHANGE THIS before any non-local deployment — the shipped default is public.
REP_SECRET=reputify-dev-secret
