# Remi — BSV configuration
#
# The prototype anchors commitment hashes on the BSV *testnet*. To broadcast
# real transactions you need a funded testnet key:
#
#   1. Start the app, open /borrower, click "Generate anchoring key" — it prints
#      a testnet address, or generate one with any BSV wallet.
#   2. Fund it from a faucet, e.g. https://witnessonchain.com/faucet/tbsv
#   3. Put the WIF (private key) below and restart.
#
# With no funded key the app runs in SIMULATED anchor mode: it still builds a
# real, signed BSV transaction and computes its real txid, but does not
# broadcast it. The UI clearly labels which mode produced each anchor.

REMI_BSV_NETWORK=test
REMI_BSV_WIF=
# ARC broadcaster endpoint (testnet). Leave default unless you run your own.
REMI_ARC_URL=https://arc.gorillapool.io
# Server-side secret for the anti-Sybil HMAC and consent signing (demo value).
REMI_HMAC_SECRET=remi-dev-secret-change-me
