# Reputify — environment configuration
#
# Nothing here is required to run the demo: with no keys set, Hedera anchoring
# and the OpenAI features fall back to clearly-labelled simulated/heuristic modes
# so the app always runs end to end. Fill these in to go "live".

# ── Hedera (credit-passport anchoring: DID / KYC / Passport / consent) ──
# Create a testnet account at https://portal.hedera.com, then set:
HEDERA_NETWORK=testnet
HEDERA_OPERATOR_ID=
HEDERA_OPERATOR_KEY=
# Optional: pin to one topic instead of letting the app create one on first anchor.
HEDERA_TOPIC_ID=

# ── Hedera (attestation-and-lending module: /rep /borrower /lender /attester) ──
# Kept on its own topic so the two on-chain worlds never mix messages.
# Reuses HEDERA_NETWORK / HEDERA_OPERATOR_ID / HEDERA_OPERATOR_KEY above.
HEDERA_ATTEST_TOPIC_ID=

# ── OpenAI (help chatbot + LLM fraud verdict at Passport build time) ──
# Without this, fraud analysis falls back to the deterministic heuristic engine.
OPENAI_API_KEY=

# ── Server-side secrets ──
# HMAC key for the anti-Sybil nullifier + consent signing salt.
# CHANGE THIS before any non-local deployment — the shipped default is public.
REMI_HMAC_SECRET=remi-dev-secret-change-me
# Key used to seal PSP OAuth tokens at rest in the attestation module.
# CHANGE THIS before any non-local deployment.
REP_SECRET=reputify-dev-secret
